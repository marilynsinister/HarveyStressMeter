{
  "name": "darkness_therapy_step1",
  "description": "Терапия темноты шаг 1: 3 вечера по 60 минут дома при свете, финал с Харви.",
  "notes": "Используй stress_darkness_add_minutes вместо часового ожидания. FarmHouse = дом игрока.",
  "tests": [
    {
      "id": "TC-DARK-001",
      "title": "Старт терапии и статус",
      "preconditions": ["Save loaded"],
      "steps": [
        { "tool": "stress_darkness_set_level", "arguments": { "level": 1 }, "expect": ["ok: true"] },
        { "tool": "stress_darkness_start_therapy", "arguments": {}, "expect": ["IsTherapyActive: true", "TherapyStage: 1"] },
        { "tool": "mcp_set_time", "arguments": { "time": 2000 }, "expect": [] },
        { "tool": "mcp_warp", "arguments": { "location": "FarmHouse" }, "expect": [] },
        { "tool": "stress_darkness_status", "arguments": {}, "expect": ["active=true", "stage=1", "evenings=0/3"] }
      ]
    },
    {
      "id": "TC-DARK-002",
      "title": "30/60 в квесте",
      "steps": [
        { "tool": "stress_darkness_add_minutes", "arguments": { "minutes": 30 }, "expect": ["todayMin=30/60"] },
        { "tool": "stress_darkness_status", "arguments": {}, "expect": ["Сегодня: 30/60"] }
      ]
    },
    {
      "id": "TC-DARK-003",
      "title": "Зачёт вечера 1/3",
      "steps": [
        { "tool": "stress_darkness_complete_evening", "arguments": {}, "expect": ["evenings=1/3", "todayCompleted=True"] },
        { "tool": "stress_darkness_complete_evening", "arguments": {}, "expect": ["evenings=1/3"] }
      ],
      "assertions": ["Второй complete_evening в тот же день не увеличивает evenings"]
    },
    {
      "id": "TC-DARK-004",
      "title": "3/3 — поговорить с Харви",
      "steps": [
        { "tool": "stress_darkness_reset_therapy", "arguments": {}, "expect": [] },
        { "tool": "stress_darkness_step1_progress", "arguments": { "evenings": 3, "today": 0 }, "expect": ["evenings=3"] },
        { "tool": "stress_darkness_status", "arguments": {}, "expect": ["Поговорите с Харви", "topicDarknessStep1ReadyForHarvey: active"] }
      ]
    }
  ]
}
