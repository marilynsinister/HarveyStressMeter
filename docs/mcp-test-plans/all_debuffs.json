      "snapshots_after": ["stress_treatment_snapshot"],
      "snapshots": ["stress_treatment_snapshot", "stress_load_debug"],
      "steps": [
        { "tool": "stress_reset", "arguments": {}, "expect": [] },
        { "tool": "stress_add_debuff", "arguments": { "buff_id": "buffStressSocial" }, "expect": [] },
        { "tool": "stress_remove_debuff", "arguments": { "buff_id": "buffStressSocial" }, "expect": [] }
      ],
      "assertions": ["Social debuff add/remove clean"]
    },
    {
      "id": "TC-DEB-Multi",
      "title": "Stack multiple debuffs then reset",
      "preconditions": ["stress_reset done"],
      "snapshots_before": ["stress_treatment_snapshot"],
      "snapshots_after": ["stress_treatment_snapshot", "stress_load_debug"],
      "snapshots": ["stress_treatment_snapshot", "stress_load_debug", "stress_debug_dump"],
      "steps": [
        { "tool": "stress_reset", "arguments": {}, "expect": [] },
        { "tool": "stress_add_debuff", "arguments": { "buff_id": "buffStressHunger" }, "expect": [] },
        { "tool": "stress_add_debuff", "arguments": { "buff_id": "buffStressTired" }, "expect": [] },
        { "tool": "stress_add_debuff", "arguments": { "buff_id": "buffStressLonely" }, "expect": [] },
        { "tool": "stress_treatment_snapshot", "arguments": {}, "expect": ["ActiveDebuffs:"] },
        { "tool": "stress_force_recalculate", "arguments": {}, "expect": [] },
        { "tool": "stress_load_debug", "arguments": {}, "expect": ["activeCauseCount:"] },
        { "tool": "stress_reset", "arguments": {}, "expect": ["ActiveTreatments count: 0"] }
      ],
      "assertions": [
        "activeCauseCount >= 3 before final reset",
        "stress_reset clears all debuffs and treatments"
      ]
    },
    {
      "id": "TC-DEB-Invalid",
      "title": "Reject unknown buff_id",
      "preconditions": ["stress_reset done"],
      "snapshots_before": ["stress_treatment_snapshot"],
      "snapshots_after": ["stress_treatment_snapshot"],
      "snapshots": ["stress_treatment_snapshot"],
      "steps": [
        { "tool": "stress_add_debuff", "arguments": { "buff_id": "buffStressNotReal" }, "expect": ["Error:"] }
      ],
      "assertions": ["Response starts with Error:", "No new ActiveDebuffs"]
    }
  ]
}
