    public sealed class StateVm : INotifyPropertyChanged
    {
        public event PropertyChangedEventHandler? PropertyChanged;
        public string Id { get; set; } = "";
        public string Title { get; set; } = "";
        public string EffectsText { get; set; } = "";
        public string CauseText { get; set; } = "";
        public string CureText { get; set; } = "";
        public string UISpriteKey { get; set; } = ""; // <— ДЛЯ ИКОНКИ В HANDBOOK

        // прогресс лечения
        private int _cur, _max;
        public int ProgressCurrent { get => _cur; set { _cur = value; PropertyChanged?.Invoke(this, new("ProgressText")); } }
        public int ProgressMax { get => _max; set { _max = value; PropertyChanged?.Invoke(this, new("ProgressText")); } }
        public string ProgressText => (ProgressMax > 0) ? $"Прогресс: {ProgressCurrent}/{ProgressMax}" : "";
        public string HarveyComment { get; set; } = "";
    }


