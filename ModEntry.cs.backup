        private IEnumerable<StateVm> EnumerateAllStates()
        {
            // Пугающая гроза
            yield return new StateVm
            {
                Id = B_Thunder,
                Title = "Пугающая гроза",
                UISpriteKey = UI("buffStressThunder"),
                EffectsText = "Эффекты: -1 защита.",
                CauseText = "Причина: гроза на улице.",
                CureText = "Лечение: проведите 120 сек рядом с Харви в укрытии."
            };

            // Боязнь темноты
            yield return new StateVm
            {
                Id = B_Darkness,
                Title = "Боязнь темноты",
                UISpriteKey = UI("buffStressDarkness"),
                EffectsText = "Эффекты: -1 защита.",
                CauseText = "Причина: ночь на улице (после 20:00) и вы вне дома.",
                CureText = "Лечение: пробудьте 180 сек в светлой локации (дом/клиника/купальни)."
            };

            // Одиночество
            yield return new StateVm
            {
                Id = B_Lonely,
                Title = "Одиночество",
                UISpriteKey = UI("buffStressLonely"),
                EffectsText = "Эффекты: -1 защита.",
                CauseText = "Причина: целый день ни с кем не говорили.",
                CureText = "Лечение: поговорите минимум с 3 разными жителями в этот день."
            };

            // Слабость от голода
            yield return new StateVm
            {
                Id = B_Hunger,
                Title = "Слабость от голода",
                UISpriteKey = UI("buffCareTea"),
                EffectsText = "Эффекты: -20 макс. выносливости, -1 защита.",
                CauseText = "Причина: очень низкая выносливость днём.",
                CureText = "Лечение: съешьте любую еду (не в купальнях)."
            };

            // Переутомление
            yield return new StateVm
            {
                Id = B_Overwork,
                Title = "Переутомление",
                UISpriteKey = UI("buffStressOverworkCloud"),
                EffectsText = "Эффекты: -34 макс. выносливости, -1 защита.",
                CauseText = "Причина: серия тяжёлых действий без перерыва.",
                CureText = "Лечение: сделайте 3 перерыва по ~30 сек в зоне отдыха (дом/клиника/купальни)."
            };

            // Недосып
            yield return new StateVm
            {
                Id = B_NoSleep,
                Title = "Недосып",
                UISpriteKey = UI("buffStressNoSleep"),
                EffectsText = "Эффекты: -1 ко всем защитным реакциям.",
                CauseText = "Причина: поздний отбой несколько ночей подряд.",
                CureText = "Лечение: лягте спать до полуночи три раза подряд."
            };

            // Переохлаждение
            yield return new StateVm
            {
                Id = B_TooCold,
                Title = "Переохлаждение",
                UISpriteKey = UI("buffStressTooCold"),
                EffectsText = "Эффекты: -1 защита.",
                CauseText = "Причина: зима/непогода и вы на улице.",
                CureText = "Лечение: согревайтесь 120 сек в доме/клинике/купальнях."
            };

            // Усталость (лёгкая)
            yield return new StateVm
            {
                Id = B_Tired,
                Title = "Усталость",
                UISpriteKey = UI("buffStressTired"),
                EffectsText = "Эффекты: лёгкая вялость и рассеянность.",
                CauseText = "Причина: обычная нагрузка в течение дня.",
                CureText = "Лечение: короткий отдых дома или перекус."
            };

            // Аура заботы Харви (для раздела «все состояния», чтобы игрок видел бафф-поддержку)
            yield return new StateVm
            {
                Id = B_CareAura,
                Title = "Рядом с Харви",
                UISpriteKey = UI("buffCareAura"),
                EffectsText = "Эффекты: +1 защита, +10 макс. выносливости.",
                CauseText = "Причина: Харви находится рядом.",
                CureText = "Держись рядом — доктор контролирует ситуацию."
            };

            // Доп. эстетические состояния из атласа (если решишь задействовать)
            yield return new StateVm
            {
                Id = "HarveyStress.Paranoia",
                Title = "Тени вокруг",
                UISpriteKey = UI("buffStressParanoia"),
                EffectsText = "Эффекты: -2 защита, -скорость.",
                CauseText = "Причина: затяжной стресс и темнота.",
                CureText = "Лечение: поговорить с Харви и провести вечер в свете."
            };
            yield return new StateVm
            {
                Id = "HarveyStress.Numbness",
                Title = "Эмоциональное онемение",
                UISpriteKey = UI("buffStressNumbness"),
                EffectsText = "Эффекты: -удача, -скорость.",
                CauseText = "Причина: длительное перенапряжение.",
                CureText = "Лечение: несколько тёплых бесед и отдых."
            };
            yield return new StateVm
            {
                Id = "HarveyStress.Anxiety",
                Title = "Тревожность",
                UISpriteKey = UI("buffStressAnxiety"),
                EffectsText = "Эффекты: -удача, -защита.",
                CauseText = "Причина: накопившиеся факторы.",
                CureText = "Лечение: дыхательная практика и разговор с Харви."
            };
        }

        private HandbookViewModel BuildHandbookVM()
        {
            string uid = this.ModManifest.UniqueID;
            // Карта: бафф -> ключ иконки
            var iconKeyByBuff = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
            {
                [B_Overwork] = "Overwork",
                [B_Lonely] = "Lonely",
                [B_Thunder] = "Storm",
                [B_Darkness] = "LateNight",
                [B_NoSleep] = "Insomnia",
                [B_Hunger] = "Tea",      // символ «еда/тёплое»
                [B_TooCold] = "Cold",
                [B_Tired] = "Glass",    // «хрупкость/усталость»
                [B_CareAura] = "Heart",

                ["HarveyStress.Paranoia"] = "Shadow",
                ["HarveyStress.Numbness"] = "Numb",
                ["HarveyStress.Anxiety"] = "Hands"
            };


            // Описания—возьмите ваши тексты/локализацию
            var data = EnumerateAllStates(); // ← ваш метод, возвращающий: id, title, effects, causes, cures[] и т.п.

            // какие баффы сейчас на игроке
            var activeBuffIds = GetCurrentStressBuffIds(); // см. ниже

            var vm = new HandbookViewModel();

            foreach (var s in data)
            {

                if (_iconsTex is null)
                    _iconsTex = Helper.ModContent.Load<Texture2D>("assets/sprites/stressIcons.png");

                string iconKey = iconKeyByBuff.TryGetValue(s.Id, out var k) ? k : "Blank";


                Rectangle src = _iconRects[iconKey]; // iconKey — имя твоей иконки, например "Overwork"


                var row = new HandbookRow
                {
                    BuffId = s.Id,
                    Title = s.Title,
                    Effects = s.EffectsText,
                    Causes = s.CauseText,
                    CureSummary = s.CureText,
                    TreatmentStageText = GetTreatmentStageText(s.Id),
                    // ВАЖНО: это то, что будем биндить в SML
                    IconSprite = new SpriteView(_iconsTex, src),

                    // Можно оставить, если используешь где-то ещё
                    IconResource = $"@Mods/{this.ModManifest.UniqueID}/Sprites/stressIcons#{iconKey}",
                };

                // статус
                if (activeBuffIds.Contains(s.Id))
                {
                    var (questName, progressText) = GetCureProgressForBuff(s.Id);
                    row.StatusText = string.IsNullOrEmpty(questName)
                        ? "Есть сейчас"
                        : $"Есть сейчас · Квест: {questName} — {progressText}";
                    row.StatusColor = "#7f6139"; // активный
                    vm.ActiveStates.Add(row);
                }
                else
                {
                    var (_, progressText) = GetCureProgressForBuff(s.Id);
                    row.StatusText = string.IsNullOrEmpty(progressText) ? "Не активен" : progressText;
                    row.StatusColor = string.IsNullOrEmpty(progressText) ? "#6b6b6b" : "#228B22"; // неактивный/завершено
                }
                vm.AllStates.Add(row);

            }

            // Активные выносим вверх
            vm.ActiveStates.Sort((a, b) => string.Compare(a.Title, b.Title, StringComparison.CurrentCulture));
            vm.AllStates.Sort((a, b) => string.Compare(a.Title, b.Title, StringComparison.CurrentCulture));
            return vm;

        }

